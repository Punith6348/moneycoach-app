{
  "appId": "com.turings.moneycoach",
  "appName": "Money Coach",
  "webDir": "dist",
  "server": {
    "hostname": "moneycoach-app.vercel.app",
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "*.firebaseapp.com",
      "*.googleapis.com",
      "*.google.com",
      "*.firebase.com",
      "*.firebasestorage.app",
      "moneycoach-app.vercel.app",
      "*.apple.com"
    ]
  },
  "ios": {
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false
  }
}
