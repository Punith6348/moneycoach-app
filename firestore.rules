rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User data — only the owning user can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // FCM push tokens — Cloud Function (admin SDK) bypasses these rules for reads.
    // Authenticated users may only write their own UID doc.
    // Unauthenticated (guest) devices may write any doc — they use a device UUID
    // as the doc ID, so collisions with real UIDs are astronomically unlikely.
    // This prevents an authenticated attacker from overwriting another user's token.
    match /fcmTokens/{tokenId} {
      allow write: if request.auth == null
                   || request.auth.uid == tokenId;
    }
  }
}
